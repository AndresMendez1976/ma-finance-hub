{
  "name": "ma-finance-hub",
  "version": "0.1.0",
  "description": "MA Finance Hub - Finance SaaS / Standalone Platform",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "prebuild": "node -e \"fs=require('fs');['dist','tsconfig.build.tsbuildinfo'].forEach(p=>{fs.rmSync(p,{recursive:true,force:true})})\"",
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,test}/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:integration": "jest --config test/jest-integration.config.ts --runInBand",
    "migrate:latest": "knex migrate:latest --knexfile knexfile.ts",
    "migrate:rollback": "knex migrate:rollback --knexfile knexfile.ts",
    "migrate:status": "knex migrate:status --knexfile knexfile.ts",
    "migrate:make": "knex migrate:make --knexfile knexfile.ts -x ts",
    "generate:keys": "node scripts/generate-dev-keys.js"
  },
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "3.750.0",
    "@nestjs/common": "10.4.15",
    "@nestjs/config": "3.3.0",
    "@nestjs/core": "10.4.15",
    "@nestjs/passport": "10.0.3",
    "@nestjs/platform-express": "10.4.15",
    "@nestjs/swagger": "7.4.2",
    "@nestjs/throttler": "6.3.0",
    "@types/pdfkit": "^0.17.5",
    "bcryptjs": "2.4.3",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.1",
    "compression": "1.7.5",
    "helmet": "7.2.0",
    "ioredis": "5.4.2",
    "joi": "17.13.3",
    "jsonwebtoken": "9.0.2",
    "knex": "3.1.0",
    "passport": "0.7.0",
    "passport-jwt": "4.0.1",
    "pdfkit": "^0.18.0",
    "pg": "8.13.1",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1",
    "uuid": "9.0.1"
  },
  "devDependencies": {
    "@nestjs/cli": "10.4.9",
    "@nestjs/testing": "10.4.15",
    "@testcontainers/postgresql": "10.16.0",
    "@types/bcryptjs": "2.4.6",
    "@types/compression": "1.7.5",
    "@types/jest": "29.5.14",
    "@types/jsonwebtoken": "9.0.7",
    "@types/passport-jwt": "4.0.1",
    "@types/supertest": "6.0.2",
    "@types/uuid": "9.0.8",
    "@typescript-eslint/eslint-plugin": "7.18.0",
    "@typescript-eslint/parser": "7.18.0",
    "eslint": "8.57.1",
    "eslint-config-prettier": "9.1.0",
    "jest": "29.7.0",
    "prettier": "3.4.2",
    "supertest": "6.3.4",
    "testcontainers": "10.16.0",
    "ts-jest": "29.2.5",
    "ts-node": "10.9.2",
    "typescript": "5.6.3"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
