# ======================================
# MA Finance Hub — VM Production Config
# Domain: maishq.com
# TLS: Cloudflare (proxy mode, orange cloud)
# VM: nginx reverse proxy, HTTP only (port 80)
# ======================================

# ── App ──
NODE_ENV=production
PORT=3000
API_PREFIX=api/v1

# ── Database ──
DB_HOST=postgres
DB_PORT=5432
DB_NAME=ma_finance_hub
DB_USER=app_user
DB_PASSWORD=CHANGE_ME_app_password
DB_SSL=false
DB_MIGRATION_USER=migration_user
DB_MIGRATION_PASSWORD=CHANGE_ME_migration_password
POSTGRES_PASSWORD=CHANGE_ME_postgres_superuser

# ── Redis ──
REDIS_URL=redis://redis:6379

# ── JWT (auto-generated by generate-vm-env.js) ──
JWT_PUBLIC_KEY=
JWT_PRIVATE_KEY=
JWT_AUDIENCE=ma-finance-hub
JWT_ISSUER_WHITELIST=ma-finance-hub-dev
JWT_DEV_KID=prod-key-001

# ── Internal Ops ──
INTERNAL_OPS_SECRET=CHANGE_ME_minimum_32_chars_hmac_secret
INTERNAL_API_KEY=CHANGE_ME_internal_api_key

# ── CORS ──
CORS_ORIGINS=https://maishq.com

# ── Logging ──
LOG_LEVEL=info
