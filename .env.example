# ── App ──
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# ── Database (app runtime connection) ──
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ma_finance_hub
DB_USER=app_user
DB_PASSWORD=app_password_dev
DB_SSL=false

# ── Database (migration connection) ──
DB_MIGRATION_USER=migration_user
DB_MIGRATION_PASSWORD=migration_password_dev

# ── JWT ──
JWT_DEV_PRIVATE_KEY_PATH=./keys/dev-private.pem
JWT_DEV_PUBLIC_KEY_PATH=./keys/dev-public.pem
JWT_DEV_KID=dev-key-001
JWT_AUDIENCE=ma-finance-hub
JWT_ISSUER_WHITELIST=ma-chiro-bill-suite,inip,ma-finance-hub-dev

# ── Swagger ──
SWAGGER_ENABLED=true

# ── Logging ──
LOG_LEVEL=debug

# ── Internal API ──
INTERNAL_API_KEY=
# Production: set JWT_PUBLIC_KEY directly (PEM content, not path)
JWT_PUBLIC_KEY=

# ── CORS ──
# Comma-separated list of allowed origins. Empty = CORS disabled.
CORS_ORIGINS=

# ── Internal Ops (Production: use HMAC mode) ──
# INTERNAL_OPS_SECRET=<32+ char secret for HMAC signing>
# Dev fallback: INTERNAL_API_KEY for static key mode

# ── Redis (optional, for multi-instance) ──
# REDIS_URL=redis://localhost:6379
